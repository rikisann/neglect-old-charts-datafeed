generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Holder {
  tokenAddress     String
  address          String
  amount           Float
  percentage_owned Float
  lastUpdated      DateTime?
  Token            Token     @relation(fields: [tokenAddress], references: [address], onDelete: Cascade)

  @@id([tokenAddress, address])
  @@index([tokenAddress, percentage_owned(sort: Desc)])
}

model Token {
  address                     String    @id @unique
  name                        String?
  symbol                      String?
  description                 String?
  price                       Float?
  mcap                        Float?
  website                     String?
  baseVault                   String?
  quoteVault                  String?
  image                       String?
  twitter                     String?
  holdersCount                Int       @default(0)
  telegram                    String?
  discord                     String?
  marketAddress               String?   @unique
  buys                        Int       @default(0)
  sells                       Int       @default(0)
  top10HoldersPercentage      Float?
  devHoldingsPercentage       Float?
  latestCtoTimestamp          DateTime?
  graduatedAt                 DateTime? @default(now())
  latestTokenProfileTimestamp DateTime?
  isMigrating                 Boolean   @default(true)
  createdAt                   DateTime  @default(now())
  devWallet                   String?
  bondingCurve                String?
  supply                      Float?
  decimals                    Int?
  liquidity                   Float?
  txns                        Int       @default(0)
  volume                      Float     @default(0)
  Holder                      Holder[]
  Swap                        Swap[]

  @@index([address])
  @@index([graduatedAt(sort: Desc)])
  @@index([mcap, graduatedAt(sort: Desc)])
  @@index([isMigrating])
  @@index([price, graduatedAt(sort: Desc)])
  @@index([volume, graduatedAt(sort: Desc)])
}

model Swap {
  id               String    @id
  tokenAddress     String
  swapType         SwapType
  tokenAmount      Float
  solAmount        Float
  signature        String
  maker            String
  baseVaultAmount  Float
  quoteVaultAmount Float
  liquidity        Float
  totalUsd         Float
  price            Float
  mcap             Float
  timestamp        DateTime? @default(now())
  Token            Token     @relation(fields: [tokenAddress], references: [address], onDelete: Cascade)

  @@index([tokenAddress, timestamp])
}

enum SwapType {
  buy
  sell
}
